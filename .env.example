OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# General endpoint (default)
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
